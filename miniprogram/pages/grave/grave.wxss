.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: #F5F5F5;
}

.search-bar {
  background: #FFFFFF;
  padding: 20rpx;
  border-bottom: 1rpx solid #E5E5E5;
  position: sticky;
  top: 0;
  z-index: 100;
}

.member-header {
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.member-name {
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
}

.member-desc {
  font-size: 28rpx;
  color: #999999;
  margin-left: 12rpx;
}

.search-input {
  width: 100%;
  height: 64rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.filter-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-btn {
  padding: 8rpx 24rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
  flex-shrink: 0;
}

.filter-btn.active {
  background: #8B4513;
  color: #FFFFFF;
}

.grave-list {
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
  height: calc(100vh - 180rpx);
}

.grave-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.grave-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}

.grave-info {
  flex: 1;
  min-width: 0;
}

.grave-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.grave-name {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.grave-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #F5E6D3;
}

.grave-detail {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

.detail-icon {
  margin-right: 8rpx;
}

.grave-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  padding-left: 16rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  color: #999999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #999999;
}

.add-btn {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  width: 96rpx;
  height: 96rpx;
  background: #8B4513;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.4);
}

.add-btn text {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 300;
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #999999;
  font-size: 26rpx;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #CCCCCC;
  font-size: 24rpx;
}
