.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.form-section {
  background: #FFFFFF;
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.member-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.member-picker text {
  flex-shrink: 0;
}

.member-picker .picker-text {
  flex: 1;
  text-align: center;
  padding-bottom: 40rpx;
  /* height: 80rpx; */
  /* line-height: 80rpx; */
}

.member-picker .placeholder {
  color: #999999;
}

.arrow {
  color: #999999;
}

.type-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-option {
  padding: 16rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.type-option.active {
  background: var(--type-color);
  color: #FFFFFF;
}

.location-input {
  display: flex;
  gap: 16rpx;
}

.location-input .input {
  flex: 1;
}

.location-btn {
  width: 80rpx;
  height: 80rpx;
  background: #8B4513;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.location-hint {
  font-size: 24rpx;
  color: #8B4513;
  margin-top: 12rpx;
}

.location-coords {
  font-size: 24rpx;
  color: #8B4513;
  margin-top: 12rpx;
}

.coords-input {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 8rpx;
}

.coord-input {
  flex: 1;
  height: 64rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.coord-sep {
  color: #999999;
  font-size: 28rpx;
}

.coord-hint {
  font-size: 22rpx;
  color: #999999;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.photo-container {
  width: 100%;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.photo-item {
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background: #F0F0F0;
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
}

.photo-add {
  aspect-ratio: 1;
  border-radius: 12rpx;
  background: #F5F5F5;
  border: 2rpx dashed #DDDDDD;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #CCCCCC;
}

.save-btn {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  height: 88rpx;
  background: #8B4513;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.3);
}

.save-btn.loading {
  opacity: 0.7;
}

.save-btn.hidden {
  display: none;
}

.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.member-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 70vh;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #E5E5E5;
  font-size: 32rpx;
  font-weight: 500;
}

.close-btn {
  font-size: 48rpx;
  color: #999999;
  padding: 0 16rpx;
}

.search-box {
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.search-input {
  width: 100%;
  height: 64rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.modal-content {
  flex: 1;
  padding: 20rpx 32rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  height: 400rpx;
  box-sizing: border-box;
}

.member-option {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
  background: #FFFFFF;
}

.member-option:active {
  background: #F5F5F5;
}

.member-option.selected {
  background: #FDF8F3;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #8B4513;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  overflow: hidden;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.member-avatar text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  display: block;
}

.member-meta {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
  display: block;
}

.check-icon {
  font-size: 36rpx;
  color: #8B4513;
  font-weight: bold;
}

.empty-hint {
  text-align: center;
  padding: 60rpx;
  color: #999999;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  border-top: 1rpx solid #E5E5E5;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.cancel-btn {
  background: #F5F5F5;
  color: #666666;
}

.confirm-btn {
  background: #8B4513;
  color: #FFFFFF;
}
