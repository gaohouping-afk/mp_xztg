.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.form-section {
  background: #FFFFFF;
  padding: 0 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E5E5E5;
}

.form-item.column {
  align-items: flex-start;
  flex-direction: column;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333333;
  flex-shrink: 0;
}

.form-item.column .label {
  width: 100%;
  margin-bottom: 16rpx;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.textarea {
  flex: 1;
  min-height: 100rpx;
  font-size: 28rpx;
  color: #333333;
}

.textarea.content {
  min-height: 300rpx;
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-image {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #D2B48C;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-image text {
  color: #D2B48C;
  font-size: 48rpx;
}

.save-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  height: 88rpx;
  background: #8B4513;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn text {
  color: #FFFFFF;
  font-size: 32rpx;
}

.year-input-row {
  display: flex;
  align-items: center;
  flex: 1;
}

.year-era-picker {
  width: 120rpx;
  height: 64rpx;
  background: #F5F5F5;
  border: 1rpx solid #E5E5E5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #333333;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.year-input {
  width: 120rpx;
  text-align: center;
}

.year-suffix {
  font-size: 28rpx;
  color: #666666;
  margin-left: 8rpx;
}
