.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: #F5F5F5;
  overflow-x: hidden;
}

.search-bar {
  background: #FFFFFF;
  padding: 20rpx;
  border-bottom: 1rpx solid #E5E5E5;
  box-sizing: border-box;
}

.search-input {
  width: 100%;
  height: 64rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.filter-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.filter-btn {
  padding: 8rpx 24rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
}

.filter-btn.active {
  background: #8B4513;
  color: #FFFFFF;
}

.member-list {
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.member-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #8B4513;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-name {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.member-generation {
  font-size: 22rpx;
  color: #8B4513;
  background: #F5E6D3;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.member-detail {
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

.member-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.action-btn.delete {
  color: #FF6B6B;
  background: #FFF0F0;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #999999;
  font-size: 28rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #999999;
}

.add-btn {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  width: 96rpx;
  height: 96rpx;
  background: #8B4513;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.4);
}

.add-btn text {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 300;
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #999999;
  font-size: 26rpx;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #CCCCCC;
  font-size: 24rpx;
}
