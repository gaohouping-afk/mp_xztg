.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.about-header {
  background: #8B4513;
  padding: 60rpx 32rpx;
  text-align: center;
}

.app-name {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.version {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.section {
  background: #FFFFFF;
  margin-top: 20rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.feature-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.feature-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.tech-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tech-item {
  font-size: 28rpx;
  color: #666666;
}

.about-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.footer {
  padding: 60rpx 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}