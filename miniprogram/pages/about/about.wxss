.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.about-header {
  background: #8B4513;
  padding: 60rpx 32rpx;
  text-align: center;
}

.app-name {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.version {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 16rpx;
  font-style: italic;
}

.section {
  background: #FFFFFF;
  margin-top: 20rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.feature-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.feature-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.tech-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tech-item {
  font-size: 28rpx;
  color: #666666;
}

.repo-box {
  background: #F5F5F5;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
}

.repo-url {
  font-size: 26rpx;
  color: #8B4513;
  word-break: break-all;
}

.contact-button {
  width: 100%;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  font-size: 0;
}

.contact-button::after {
  border: none;
}

.contact-wrapper {
  margin-top: 20rpx;
}

.contact-box {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #8B4513, #A0522D);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.25);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.contact-button:active .contact-box {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.15);
}

.contact-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.contact-info {
  flex: 1;
  text-align: left;
}

.contact-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.contact-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.contact-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
}

.about-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.footer {
  padding: 60rpx 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}