.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: #F5F5F5;
}

.story-list {
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.story-item {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.story-year {
  width: 140rpx;
  min-width: 140rpx;
  background: #8B4513;
  color: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 12rpx 8rpx;
}

.year-era {
  font-size: 20rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.year-num {
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1.2;
}

.story-content {
  flex: 1;
  padding: 20rpx;
  min-width: 0;
}

.story-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.story-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.story-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999999;
}

.story-actions {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.action-btn.delete {
  color: #FF6B6B;
  background: #FFF0F0;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #999999;
  font-size: 28rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #999999;
}

.add-btn {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  width: 96rpx;
  height: 96rpx;
  background: #8B4513;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.4);
}

.add-btn text {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 300;
}
