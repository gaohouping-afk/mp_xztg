.page-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #F5F5F5;
}

.search-bar {
  background: #FFFFFF;
  padding: 20rpx;
  border-bottom: 1rpx solid #E5E5E5;
  z-index: 10;
}

.search-input-wrapper {
  position: relative;
  margin-bottom: 16rpx;
}

.search-results {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border: 1rpx solid #E5E5E5;
  border-top: none;
  border-radius: 0 0 16rpx 16rpx;
  max-height: 400rpx;
  overflow-y: auto;
  z-index: 100;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.1);
}

.search-result-item {
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #F5F5F5;
}

.search-result-item:active {
  background: #F5F5F5;
}

.filter-row {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.branch-picker {
  display: flex;
  align-items: center;
  padding: 8rpx 24rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
  gap: 8rpx;
}

.branch-picker.selected {
  background: #8B4513;
  color: #FFFFFF;
}

.picker-arrow {
  font-size: 18rpx;
  margin-left: 4rpx;
}

.search-input {
  width: 100%;
  height: 64rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.filter-btns {
  display: flex;
  gap: 12rpx;
}

.filter-btn {
  padding: 8rpx 24rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
}

.filter-btn.active {
  background: #8B4513;
  color: #FFFFFF;
}

.tree-wrapper {
  flex: 1;
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
  background-color: #FAF9F5;
}

.tree-scroll {
  width: 100%;
  height: 100%;
}

.tree-inner {
  position: relative;
  padding-top: 40rpx;
  white-space: nowrap;
}

.loading {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #999999;
  z-index: 100;
}

.fab-group {
  position: fixed;
  bottom: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 1000;
}

.fab-group.left {
  left: 24rpx;
}

.fab-group.right {
  right: 24rpx;
}

.fab-btn {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 4rpx 12rpx rgba(139, 69, 19, 0.3),
    0 2rpx 4rpx rgba(0, 0, 0, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.fab-btn:active {
  transform: scale(0.92);
  box-shadow: 
    0 2rpx 6rpx rgba(139, 69, 19, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.fab-btn.zoom-in,
.fab-btn.zoom-out {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
}

.fab-btn.reset-zoom {
  background: linear-gradient(135deg, #FFFFFF 0%, #F5F5F5 100%);
  border: 1rpx solid rgba(139, 69, 19, 0.2);
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
}

.fab-btn.reset,
.fab-btn.add {
  background: linear-gradient(135deg, #FFFFFF 0%, #F5F5F5 100%);
  border: 1rpx solid rgba(139, 69, 19, 0.2);
  width: 88rpx;
  height: 88rpx;
}

.fab-icon {
  line-height: 1;
}

.fab-btn.reset .fab-icon,
.fab-btn.add .fab-icon {
  width: 44rpx;
  height: 44rpx;
}

.fab-btn.reset-zoom .fab-icon {
  width: 40rpx;
  height: 40rpx;
}

.fab-btn.zoom-in .fab-icon,
.fab-btn.zoom-out .fab-icon {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 500;
}
