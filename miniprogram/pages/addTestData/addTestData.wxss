.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.tree-preview {
  margin: 40rpx 0;
  padding: 30rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  width: 80%;
}

.gen {
  font-size: 28rpx;
  color: #333;
  text-align: center;
  padding: 10rpx 0;
}

.line {
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.btn {
  width: 80%;
  background-color: #8B4513;
  color: white;
  border-radius: 10rpx;
  margin-top: 40rpx;
}

.progress-box {
  width: 80%;
  margin-top: 40rpx;
}

.status-text {
  font-size: 24rpx;
  color: #8B4513;
  text-align: center;
  margin-top: 12rpx;
}
