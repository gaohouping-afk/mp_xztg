.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.story-header {
  background: #FFFFFF;
  padding: 32rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.story-year {
  display: inline-block;
  background: #8B4513;
  color: #FFFFFF;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.story-title {
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.story-meta {
  display: flex;
  gap: 24rpx;
  font-size: 26rpx;
  color: #666666;
}

.story-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.story-body {
  background: #FFFFFF;
  padding: 32rpx;
  margin-top: 20rpx;
}

.story-text {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.8;
}

.story-images {
  background: #FFFFFF;
  padding: 32rpx;
  margin-top: 20rpx;
}

.story-img {
  width: 100%;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.edit-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  height: 88rpx;
  background: #8B4513;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-btn text {
  color: #FFFFFF;
  font-size: 32rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #999999;
}
