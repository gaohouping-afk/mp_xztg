page {
  background-color: #F5F5F5;
}

.container {
  padding: 40rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 60rpx 0;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 48rpx;
  color: #8B4513;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999999;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-top: 40rpx;
}

.menu-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  background: #8B4513;
  border-radius: 16rpx;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.menu-text {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.menu-desc {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

.init-section {
  margin-top: 80rpx;
  text-align: center;
}

.init-btn {
  background: #8B4513;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  border: none;
  margin-bottom: 20rpx;
}

.test-btn {
  background: #4A90D9;
}

.danger-btn {
  background: #FF6B6B;
  color: #FFFFFF;
}

.init-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}
