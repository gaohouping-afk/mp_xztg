.page {
  min-height: 100vh;
  background: #F8F6F3;
}

.hero-section {
  position: relative;
  padding: 120rpx 40rpx 100rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #CD853F 100%);
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.hero-badge {
  width: 180rpx;
  height: 180rpx;
  display: inline-block;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.hero-title {
  font-size: 56rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  background: linear-gradient(90deg, #FFFFFF, #FFF8DC, #FFE4B5, #FFF8DC, #FFFFFF);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  animation: gradientMove 2.5s ease-in-out infinite;
}

.hero-subtitle {
  font-size: 28rpx;
  letter-spacing: 2rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0.9), rgba(255,250,205,0.95), rgba(255,255,255,0.9), rgba(255,250,205,0.95), rgba(255,255,255,0.9));
  background-size: 200% 100%;
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  animation: subtitleShimmer 3.5s ease-in-out infinite;
}

@keyframes gradientMove {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes subtitleShimmer {
  0%, 100% { background-position: 0% 50%; opacity: 0.8; }
  50% { background-position: 100% 50%; opacity: 1; }
}

.menu-container {
  padding: 40rpx 32rpx;
  position: relative;
  z-index: 2;
}

.menu-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 69, 19, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  position: relative;
  overflow: hidden;
}

.menu-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.menu-card:nth-child(1)::before {
  background: linear-gradient(180deg, #8B4513, #A0522D);
}

.menu-card:nth-child(2)::before {
  background: linear-gradient(180deg, #A0522D, #B8860B);
}

.menu-card:nth-child(3)::before {
  background: linear-gradient(180deg, #B8860B, #DAA520);
}

.menu-card:nth-child(4)::before {
  background: linear-gradient(180deg, #DAA520, #CD853F);
}

.menu-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(139, 69, 19, 0.06);
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
  background: #FDF8F5;
}

.menu-card:nth-child(1) .card-icon {
  background: rgba(139, 69, 19, 0.12);
}

.menu-card:nth-child(2) .card-icon {
  background: rgba(160, 82, 45, 0.12);
}

.menu-card:nth-child(3) .card-icon {
  background: rgba(184, 134, 11, 0.12);
}

.menu-card:nth-child(4) .card-icon {
  background: rgba(205, 133, 63, 0.12);
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.card-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.family-switch-pill {
  position: absolute;
  top: 40rpx;
  right: 32rpx;
  z-index: 10;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  border-radius: 50rpx;
  padding: 12rpx 24rpx;
  max-width: 320rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.switch-pill-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 220rpx;
}

.switch-pill-arrow {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 10rpx;
}

.family-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 900;
  pointer-events: none;
  transition: background 0.3s ease;
}

.family-picker-mask.show {
  background: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

.family-picker-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 901;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.family-picker-panel.show {
  transform: translateY(0);
}

.picker-handle {
  width: 60rpx;
  height: 8rpx;
  background: #DDDDDD;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}

.picker-header {
  padding: 32rpx 40rpx 20rpx;
  border-bottom: 1px solid #F0F0F0;
}

.picker-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 6rpx;
}

.picker-subtitle {
  font-size: 24rpx;
  color: #999999;
}

.picker-list {
  flex: 1;
  padding: 16rpx 24rpx;
  max-height: 50vh;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  background: #FAFAFA;
  transition: background 0.15s ease;
}

.picker-item.active {
  background: #F5EDE5;
}

.picker-item:active {
  background: #EDE5DC;
}

.picker-item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #8B4513, #A0522D);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.picker-item-icon text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.picker-item-info {
  flex: 1;
  min-width: 0;
}

.picker-item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-item-role {
  font-size: 24rpx;
  color: #8B4513;
}

.picker-item-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #8B4513;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.picker-item-check text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.picker-empty {
  padding: 60rpx 40rpx;
  text-align: center;
}

.picker-empty text {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.picker-empty-btn {
  display: inline-block;
  background: #8B4513;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border-radius: 50rpx;
}

.picker-footer {
  padding: 20rpx 32rpx;
  border-top: 1px solid #F0F0F0;
}

.picker-manage-btn {
  width: 100%;
  background: #F5F5F5;
  color: #666666;
  font-size: 30rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  border: none;
}

.picker-manage-btn:active {
  background: #EBEBEB;
}

.footer-section {
  padding: 40rpx 32rpx;
  text-align: center;
}

.privacy-note {
  margin-bottom: 24rpx;
  padding: 0 20rpx;
}

.privacy-note text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

.footer-buttons {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.about-btn {
  display: inline-block;
  background: transparent;
  color: #999999;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  border: 1rpx solid #E5E0D8;
  border-radius: 30rpx;
}

.about-btn::after {
  border: none;
}

.about-btn:active {
  background: #F5F3F0;
}

.sync-btn {
  position: relative;
  padding-left: 50rpx;
}

.sync-btn::before {
  content: '↻';
  position: absolute;
  left: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #8B4513;
}

.sync-btn:active {
  background: #F5F3F0;
}