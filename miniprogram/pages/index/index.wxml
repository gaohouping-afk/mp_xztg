<view class="page">
  <view class="hero-section">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <image class="hero-badge" src="/images/icons/temple.svg" mode="aspectFit" />
      <view class="hero-title">寻公问祖</view>
      <view class="hero-subtitle">追溯根源，铭记先祖</view>
    </view>
  </view>

  <view class="menu-container">
    <view class="menu-grid">
      <view class="menu-card" bindtap="goToFamilyTree">
        <image class="card-icon" src="/images/icons/family.svg" mode="aspectFit" />
        <view class="card-content">
          <text class="card-title">家族族谱</text>
          <text class="card-desc">查看族谱树</text>
        </view>
        <view class="card-arrow">›</view>
      </view>

      <view class="menu-card" bindtap="goToMember">
        <image class="card-icon" src="/images/icons/members.svg" mode="aspectFit" />
        <view class="card-content">
          <text class="card-title">成员档案</text>
          <text class="card-desc">管理成员信息</text>
        </view>
        <view class="card-arrow">›</view>
      </view>

      <view class="menu-card" bindtap="goToStory">
        <image class="card-icon" src="/images/icons/story.svg" mode="aspectFit" />
        <view class="card-content">
          <text class="card-title">迁徙故事</text>
          <text class="card-desc">家族迁徙历史</text>
        </view>
        <view class="card-arrow">›</view>
      </view>

      <view class="menu-card" bindtap="goToGrave">
        <image class="card-icon" src="/images/icons/grave.svg" mode="aspectFit" />
        <view class="card-content">
          <text class="card-title">墓碑纪念</text>
          <text class="card-desc">管理墓碑信息</text>
        </view>
        <view class="card-arrow">›</view>
      </view>
    </view>
  </view>

  <view class="footer-section">
    <view class="privacy-note">
      <text>温馨提示：数据隔离，仅见本人添加内容。</text>
    </view>
    <button class="about-btn" bindtap="goToAbout">关于</button>
  </view>
</view>