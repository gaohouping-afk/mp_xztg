<view class="container">
  <view class="header">
    <image class="logo" src="/images/logo.png" mode="aspectFit" wx:if="{{false}}"></image>
    <view class="title">族谱小程序</view>
    <view class="subtitle">记录家族历史，传承家族文化</view>
  </view>

  <view class="menu-grid">
    <view class="menu-item" bindtap="goToFamilyTree">
      <view class="menu-icon">族</view>
      <text class="menu-text">家族族谱</text>
      <text class="menu-desc">查看族谱树</text>
    </view>
    <view class="menu-item" bindtap="goToMember">
      <view class="menu-icon">成</view>
      <text class="menu-text">成员档案</text>
      <text class="menu-desc">管理成员信息</text>
    </view>
    <view class="menu-item" bindtap="goToStory">
      <view class="menu-icon">迁</view>
      <text class="menu-text">迁徙故事</text>
      <text class="menu-desc">家族迁徙历史</text>
    </view>
  </view>

  <view class="init-section">
    <!-- <button class="init-btn" bindtap="initDatabase">初始化数据库</button> -->
    <!-- <button class="init-btn test-btn" bindtap="goToAddTestData">添加测试数据</button> -->
    <!-- <button class="init-btn danger-btn" bindtap="clearAllData">清理数据</button> -->
    <button class="init-btn" bindtap="goToAbout">关于</button>
  </view>
</view>
