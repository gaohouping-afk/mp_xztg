.page {
  min-height: 100vh;
  background: #F8F6F3;
  padding-bottom: 120rpx;
}

.header-card {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.family-icon {
  font-size: 80rpx;
  margin-right: 16rpx;
}

.family-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.family-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.family-main-info {
  display: flex;
  align-items: center;
}

.switch-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #FFFFFF;
}

.family-stats {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.stat-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-divider {
  color: rgba(255, 255, 255, 0.5);
}

.empty-state {
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 48rpx;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #8B4513;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.1);
}

.action-btn.primary {
  background: linear-gradient(135deg, #8B4513, #A0522D);
  color: #FFFFFF;
}

.action-btn::after {
  border: none;
}

.invite-card {
  background: #FFFFFF;
  margin: 20rpx 32rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 69, 19, 0.08);
}

.invite-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.invite-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.invite-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.invite-content {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.invite-main {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
}

.invite-qr-section {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qrcode-container {
  width: 200rpx;
  height: 200rpx;
  background: #F8F6F3;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.qrcode-image {
  width: 200rpx;
  height: 200rpx;
}

.qrcode-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode-loading {
  font-size: 24rpx;
  color: #999999;
}

.qrcode-hint {
  font-size: 22rpx;
  color: #999999;
  margin-top: 12rpx;
}

.invite-code-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #FDF8F3, #F8F4EF);
  border-radius: 20rpx;
  padding: 32rpx;
}

.invite-code-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.invite-code-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #8B4513;
  letter-spacing: 8rpx;
  margin-bottom: 24rpx;
}

.copy-btn {
  background: linear-gradient(135deg, #8B4513, #A0522D);
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 18rpx 48rpx;
  border-radius: 40rpx;
}

.copy-btn::after {
  border: none;
}

.invite-divider {
  display: flex;
  align-items: center;
  margin: 24rpx 0;
}

.invite-divider::before,
.invite-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #E8E4DF;
}

.divider-text {
  font-size: 24rpx;
  color: #999999;
  padding: 0 20rpx;
}

.invite-hint {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.join-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.join-input {
  flex: 2;
  height: 80rpx;
  background: #F8F6F3;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #333333;
  letter-spacing: 4rpx;
}

.join-input::placeholder {
  color: #CCCCCC;
  letter-spacing: 2rpx;
}

.join-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #8B4513, #A0522D);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.join-btn::after {
  border: none;
}

.preview-card {
  background: linear-gradient(135deg, #FFF8F0, #FFF);
  border: 2rpx solid #E8D4C8;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.preview-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.preview-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.preview-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.preview-owner {
  font-size: 26rpx;
  color: #666666;
}

.preview-count {
  font-size: 26rpx;
  color: #999999;
}

.preview-join-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #8B4513, #A0522D);
  color: #FFFFFF;
  font-size: 30rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-join-btn::after {
  border: none;
}

.invite-hint {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

.qrcode-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.qrcode-modal-content {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qrcode-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.qrcode-modal-image {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 24rpx;
}

.qrcode-modal-code {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.qrcode-modal-hint {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.qrcode-modal-close {
  width: 100%;
  height: 88rpx;
  background: #F8F6F3;
  color: #666666;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode-modal-close::after {
  border: none;
}

.menu-section {
  padding: 20rpx 32rpx;
}

.menu-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(139, 69, 19, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

button.share-btn {
  width: 100%;
  background: #FFFFFF !important;
  border-radius: 24rpx;
  padding: 28rpx !important;
  margin-bottom: 20rpx;
  display: flex !important;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(139, 69, 19, 0.08);
  box-sizing: border-box;
}

button.share-btn::after {
  border: none !important;
}

.menu-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(139, 69, 19, 0.06);
}

.menu-card-left {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-start;
}

.menu-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.menu-content {
  flex: 1;
  text-align: left;
}

.menu-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
}

.loading-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F8F6F3;
  z-index: 999;
}

.loading-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  animation: bounce 1.5s ease-in-out infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.loading-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15rpx); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.family-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.family-picker-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 1001;
  max-height: 70vh;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.picker-close {
  font-size: 40rpx;
  color: #999999;
  padding: 10rpx;
}

.picker-list {
  padding: 20rpx 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  background: #F8F6F3;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.picker-item.active {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
}

.picker-item-info {
  flex: 1;
}

.picker-item-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.picker-item.active .picker-item-name {
  color: #FFFFFF;
}

.picker-item-role {
  font-size: 24rpx;
  color: #999999;
}

.picker-item.active .picker-item-role {
  color: rgba(255, 255, 255, 0.8);
}

.picker-item-check {
  font-size: 36rpx;
  color: #FFFFFF;
  margin-left: 20rpx;
}
